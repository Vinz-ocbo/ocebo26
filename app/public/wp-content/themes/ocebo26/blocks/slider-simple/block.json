{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ocebo26/slider-simple",
  "version": "1.0.0",
  "title": "Slider — Simple",
  "category": "ocebo26",
  "icon": "images-alt2",
  "description": "Carrousel d'images en boucle infinie. Image active à 100%, latérales à 20% d'opacité. Une seule image = affichage statique centré.",
  "keywords": ["slider", "carousel", "carrousel", "images"],
  "textdomain": "ocebo26",
  "attributes": {
    "slides": {
      "type": "array",
      "default": []
    }
  },
  "supports": {
    "html": false,
    "align": ["wide", "full"],
    "spacing": { "padding": true, "margin": true }
  },
  "editorScript": "file:../../build/blocks/slider-simple/index.js",
  "render": "file:./render.php",
  "style": "file:./style.css",
  "viewScript": "file:./view.js"
}
